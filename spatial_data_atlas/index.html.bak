<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Spatial & Geographical Data Visualization Atlas</title><link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet"><style>*{margin:0;padding:0;box-sizing:border-box}:root{--bg:#06080F;--bg2:#0D1117;--bg3:#161B26;--bg4:#1C2333;--bd:#21293A;--t1:#F0F3F8;--t2:#A0AEC0;--t3:#718096;--ac:#00D5E0;--pk:#FF5872}body{background:var(--bg);color:var(--t1);font-family:"Source Sans 3",system-ui,sans-serif;overflow-x:hidden}.hr{padding:2.5rem 2rem 2rem;text-align:center;background:linear-gradient(180deg,#0A0F1A,var(--bg));border-bottom:1px solid var(--bd);position:relative}.hr::after{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(0,213,224,.06),transparent);pointer-events:none}.hr *{position:relative;z-index:1}.hr h1{font-family:"Playfair Display",serif;font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:900;letter-spacing:-.03em}.hr h1 em{font-style:normal;color:var(--ac)}.hr .af{color:var(--t3);font-size:.8rem;margin-top:.3rem}.hr .su{color:var(--t2);margin-top:.4rem;font-size:.88rem;max-width:700px;margin-inline:auto;line-height:1.5}.ss{display:flex;justify-content:center;gap:2rem;margin-top:1.3rem;flex-wrap:wrap}.sv{font-family:"Playfair Display",serif;font-size:1.8rem;color:var(--ac)}.sl{font-size:.6rem;color:var(--t3);text-transform:uppercase;letter-spacing:.1em}.nv{display:flex;gap:1px;padding:0 .5rem;overflow-x:auto;background:var(--bg2);border-bottom:1px solid var(--bd);position:sticky;top:0;z-index:100}.tb{background:none;border:none;padding:.7rem .7rem;color:var(--t3);font-family:inherit;font-size:.73rem;font-weight:600;cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;transition:all .2s;display:flex;align-items:center;gap:.25rem}.tb:hover{color:var(--t1);background:var(--bg3)}.tb.active{color:var(--ac);border-bottom-color:var(--ac);background:var(--bg3)}.ti{font-size:.85rem}.tc{font-size:.58rem;background:var(--bd);border-radius:99px;padding:.08rem .35rem;color:var(--t2);margin-left:.1rem}.tb.active .tc{background:var(--ac);color:var(--bg)}.mn{max-width:1440px;margin:0 auto;padding:1.2rem}.ph{display:flex;align-items:center;gap:.8rem;margin-bottom:1.2rem}.pi{font-size:1.5rem;width:2.5rem;height:2.5rem;border-radius:8px;display:flex;align-items:center;justify-content:center}.ph h2{font-family:"Playfair Display",serif;font-size:1.3rem}.pd{color:var(--t2);font-size:.82rem;margin-top:.15rem;line-height:1.4}.cg2{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:.6rem}.cd{background:var(--bg3);border:1px solid var(--bd);border-radius:7px;cursor:pointer;transition:all .2s;display:flex;overflow:hidden;animation:fu .35s ease-out both}@keyframes fu{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}.cd:hover{background:var(--bg4);border-color:var(--ac);transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,213,224,.06)}.cs{width:3px;flex-shrink:0;border-radius:7px 0 0 7px}.cb{padding:.8rem 1rem;flex:1;min-width:0}.ct{display:flex;align-items:center;gap:.4rem;margin-bottom:.3rem}.cn{font-family:"Playfair Display",serif;font-size:1.3rem;color:#2D3748;line-height:1}.cg{font-size:.55rem;font-weight:600;padding:.1rem .4rem;border-radius:99px;background:#00D5E015;color:var(--ac);border:1px solid #00D5E033;text-transform:uppercase;letter-spacing:.03em}.cd h3{font-size:.88rem;font-weight:700;line-height:1.25;margin-bottom:.2rem}.dp{font-size:.73rem;color:var(--t2);line-height:1.45}.ca{font-size:.68rem;color:var(--ac);margin-top:.3rem;opacity:0;transition:opacity .2s}.cd:hover .ca{opacity:1}.sf{margin-top:1.5rem;padding:1.2rem;background:var(--bg2);border:1px solid var(--bd);border-radius:8px}.sf h3{font-family:"Playfair Display",serif;margin-bottom:.6rem;font-size:1rem}.sf p{color:var(--t2);font-size:.72rem;line-height:1.8}.sf a{color:var(--ac);text-decoration:none}.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:1000;justify-content:center;align-items:center;backdrop-filter:blur(4px)}.ov.sh{display:flex}.ov iframe{width:96vw;height:93vh;border:none;border-radius:8px;background:#fff}.xb{position:fixed;top:8px;right:14px;background:var(--pk);color:#fff;border:none;width:34px;height:34px;border-radius:50%;font-size:1rem;cursor:pointer;z-index:1001;display:flex;align-items:center;justify-content:center}@media(max-width:768px){.cg2{grid-template-columns:1fr}}</style></head><body><div class="hr"><h1>Spatial & Geographical <em>Data Visualization Atlas</em></h1><p class="af">Lab for Spatial Informatics, IIIT Hyderabad</p><p class="su">64 interactive visualizations: global development, elections, commodities, spatial autocorrelation, and 13 immersive 3D environments</p><div class="ss"><div><div class="sv">80</div><div class="sl">Charts</div></div><div><div class="sv">13</div><div class="sl">3D Scenes</div></div><div><div class="sv">11</div><div class="sl">Themes</div></div><div><div class="sv">8</div><div class="sl">Data Sources</div></div></div></div><nav class="nv"><button class="tb active" onclick="sw('dynamics')" id="b-dynamics"><span class="ti">&#127758;</span><span class="tl">Global Development</span><span class="tc">6</span></button>
<button class="tb" onclick="sw('animated')" id="b-animated"><span class="ti">&#127916;</span><span class="tl">Animated Temporal</span><span class="tc">6</span></button>
<button class="tb" onclick="sw('corals')" id="b-corals"><span class="ti">&#129424;</span><span class="tl">Corals & Oceans</span><span class="tc">3</span></button>
<button class="tb" onclick="sw('people')" id="b-people"><span class="ti">&#128101;</span><span class="tl">People</span><span class="tc">3</span></button>
<button class="tb" onclick="sw('poverty')" id="b-poverty"><span class="ti">&#128176;</span><span class="tl">Poverty</span><span class="tc">2</span></button>
<button class="tb" onclick="sw('usage')" id="b-usage"><span class="ti">&#128241;</span><span class="tl">Technology</span><span class="tc">3</span></button>
<button class="tb" onclick="sw('money')" id="b-money"><span class="ti">&#128181;</span><span class="tl">Money & Trade</span><span class="tc">3</span></button>
<button class="tb" onclick="sw('environment')" id="b-environment"><span class="ti">&#127795;</span><span class="tl">Environment</span><span class="tc">3</span></button>
<button class="tb" onclick="sw('geovars')" id="b-geovars"><span class="ti">&#128200;</span><span class="tl">Geo-Variables</span><span class="tc">14</span></button>
<button class="tb" onclick="sw('india')" id="b-india"><span class="ti">&#127470;&#127475;</span><span class="tl">India Elections</span><span class="tc">14</span></button>
<button class="tb" onclick="sw('delimitation')" id="b-delimitation"><span class="ti">&#9878;</span><span class="tl">Delimitation & Fiscal</span><span class="tc">10</span></button>
<button class="tb" onclick="sw('immersive')" id="b-immersive"><span class="ti">&#127922;</span><span class="tl">3D Immersive</span><span class="tc">13</span></button>
</nav><div class="mn"><div class="tp" id="p-dynamics" style="display:flex;flex-direction:column"><div class="ph"><div class="pi" style="background:#00D5E022;color:#00D5E0">&#127758;</div><div><h2>Global Development</h2><p class="pd">Animated global development 1990-2023.</p></div></div><div class="cg2"><div class="cd" onclick="op('01_gdp_vs_life_expectancy.html')" style="animation-delay:0.00s"><div class="cs" style="background:#00D5E0"></div><div class="cb"><div class="ct"><span class="cn">01</span></div><h3>Wealth vs Health</h3><p class="dp">Animated bubble chart: GDP vs life expectancy for 199 countries (1990-2023). Bubble size = population. The Preston Curve in motion.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('02_fertility_vs_life_expectancy.html')" style="animation-delay:0.04s"><div class="cs" style="background:#00D5E0"></div><div class="cb"><div class="ct"><span class="cn">02</span></div><h3>Fertility vs Longevity</h3><p class="dp">Animated bubble: fertility rate vs life expectancy. Watch the global demographic transition unfold year by year.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('03_child_mortality_vs_gdp.html')" style="animation-delay:0.08s"><div class="cs" style="background:#00D5E0"></div><div class="cb"><div class="ct"><span class="cn">03</span></div><h3>Child Mortality vs Wealth</h3><p class="dp">Under-5 mortality vs GDP per capita, animated. Humanity's greatest achievement: the dramatic decline in child death.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('04_country_trajectories.html')" style="animation-delay:0.12s"><div class="cs" style="background:#00D5E0"></div><div class="cb"><div class="ct"><span class="cn">04</span></div><h3>Country Trajectories</h3><p class="dp">14 key nations traced on the GDP-lifeExp plane over decades. See China's leap, Botswana's HIV dip, Rwanda's recovery.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('05_continental_trends.html')" style="animation-delay:0.16s"><div class="cs" style="background:#00D5E0"></div><div class="cb"><div class="ct"><span class="cn">05</span></div><h3>Continental Trends</h3><p class="dp">Three-panel continental trends: GDP (diverging), life expectancy (converging), fertility (converging). Population-weighted.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('06_income_distribution_shift.html')" style="animation-delay:0.20s"><div class="cs" style="background:#00D5E0"></div><div class="cb"><div class="ct"><span class="cn">06</span></div><h3>Income Distribution</h3><p class="dp">Global income distribution shifting from bimodal (two humps) to unimodal. The disappearing 'developed vs developing' divide.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-animated" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#E74C3C22;color:#E74C3C">&#127916;</div><div><h2>Animated Temporal</h2><p class="pd">Bar races, temporal choropleths, fertility collapse, mortality plunge.</p></div></div><div class="cg2"><div class="cd" onclick="op('49_gdp_bar_race.html')" style="animation-delay:0.00s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">49</span></div><h3>GDP Race</h3><p class="dp">Top 15 nations racing by GDP per capita, 1992-2022. Watch Ireland, Qatar, Singapore surge. Press play.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('50_india_electoral_swing.html')" style="animation-delay:0.04s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">50</span></div><h3>Electoral Swing</h3><p class="dp">Toggle between 2019 and 2024 elections. Bubbles morph as margins shift. 214 constituencies changed party.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('51_fertility_collapse.html')" style="animation-delay:0.08s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">51</span></div><h3>Fertility Collapse</h3><p class="dp">Year-by-year fertility vs life expectancy, 1990-2023. The most important demographic chart: global convergence.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('52_mortality_plunge.html')" style="animation-delay:0.12s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">52</span></div><h3>Mortality Plunge</h3><p class="dp">Animated choropleth: under-5 mortality 1990-2022. Watch Sub-Saharan Africa gradually lighten decade by decade.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('53_convergence_race.html')" style="animation-delay:0.16s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">53</span></div><h3>Convergence</h3><p class="dp">Life expectancy converging (left) while GDP diverges (right). Health interventions work; markets do not equalize.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('58_animated_inequality.html')" style="animation-delay:0.20s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">58</span></div><h3>Animated Inequality</h3><p class="dp">Gini coefficient animated 1990-2020 by 5-year bins. Latin America improving, China worsening. Policy choices matter.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-corals" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#FF587222;color:#FF5872">&#129424;</div><div><h2>Corals & Oceans</h2><p class="pd">Reef bleaching, SST, coral pulse.</p></div></div><div class="cg2"><div class="cd" onclick="op('07_coral_bleaching_map.html')" style="animation-delay:0.00s"><div class="cs" style="background:#FF5872"></div><div class="cb"><div class="ct"><span class="cn">07</span></div><h3>Reef Bleaching</h3><p class="dp">27 major reef systems. Size = area. Color = threat level. Critical reefs concentrated in the Caribbean and Coral Triangle.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('08_ocean_sst_anomaly.html')" style="animation-delay:0.04s"><div class="cs" style="background:#FF5872"></div><div class="cb"><div class="ct"><span class="cn">08</span></div><h3>Ocean SST</h3><p class="dp">Global SST anomaly 1980-2024. All 4 mass bleaching events annotated. The accelerating pace of ocean warming.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('57_coral_temporal_pulse.html')" style="animation-delay:0.08s"><div class="cs" style="background:#FF5872"></div><div class="cb"><div class="ct"><span class="cn">57</span></div><h3>Coral Pulse</h3><p class="dp">Reef map (top) + SST timeline (bottom). Cause (warming) linked to effect (bleaching). Intervals tightening.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-people" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#FFE70022;color:#FFE700">&#128101;</div><div><h2>People</h2><p class="pd">Urbanization, slums, demographics.</p></div></div><div class="cg2"><div class="cd" onclick="op('09_urbanization_choropleth.html')" style="animation-delay:0.00s"><div class="cs" style="background:#FFE700"></div><div class="cb"><div class="ct"><span class="cn">09</span></div><h3>Urbanization</h3><p class="dp">Animated world choropleth: urban population % from 1990 to 2022. Watch China and Africa transform.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('10_slum_population_map.html')" style="animation-delay:0.04s"><div class="cs" style="background:#FFE700"></div><div class="cb"><div class="ct"><span class="cn">10</span></div><h3>Slum Population</h3><p class="dp">% urban population in slums. Sub-Saharan Africa and South Asia exceed 50% in many countries.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('22_bubble_map_gdp_health.html')" style="animation-delay:0.08s"><div class="cs" style="background:#FFE700"></div><div class="cb"><div class="ct"><span class="cn">22</span></div><h3>Nations Bubble Map</h3><p class="dp">Countries at geographic coordinates. Size = population. Asia dominates. Hover for GDP and life expectancy.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-poverty" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#E74C3C22;color:#E74C3C">&#128176;</div><div><h2>Poverty</h2><p class="pd">Poverty and inequality.</p></div></div><div class="cg2"><div class="cd" onclick="op('11_extreme_poverty_map.html')" style="animation-delay:0.00s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">11</span></div><h3>Extreme Poverty</h3><p class="dp">Population below $1.90/day. The geographic concentration of extreme poverty in Sub-Saharan Africa.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('12_gini_inequality_map.html')" style="animation-delay:0.04s"><div class="cs" style="background:#E74C3C"></div><div class="cb"><div class="ct"><span class="cn">12</span></div><h3>Gini Inequality</h3><p class="dp">Gini coefficient: 0 = equality, 100 = total inequality. Latin America and Southern Africa most unequal.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-usage" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#9B59B622;color:#9B59B6">&#128241;</div><div><h2>Technology</h2><p class="pd">Digital divide, mobile, electricity.</p></div></div><div class="cg2"><div class="cd" onclick="op('13_internet_usage_choropleth.html')" style="animation-delay:0.00s"><div class="cs" style="background:#9B59B6"></div><div class="cb"><div class="ct"><span class="cn">13</span></div><h3>Internet (Animated)</h3><p class="dp">Animated choropleth: internet users % from 2000 to 2022. The digital revolution spreading North to South.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('14_electricity_access_map.html')" style="animation-delay:0.04s"><div class="cs" style="background:#9B59B6"></div><div class="cb"><div class="ct"><span class="cn">14</span></div><h3>Electricity</h3><p class="dp">% with electricity access. Sub-Saharan Africa below 20% in many countries. Energy poverty limits everything.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('15_mobile_subscriptions_map.html')" style="animation-delay:0.08s"><div class="cs" style="background:#9B59B6"></div><div class="cb"><div class="ct"><span class="cn">15</span></div><h3>Mobile</h3><p class="dp">Mobile subscriptions per 100 people. Many countries exceed 100 (multiple SIMs). The most equitable technology.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-money" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#2ECC4022;color:#2ECC40">&#128181;</div><div><h2>Money & Trade</h2><p class="pd">GDP, trade, remittances.</p></div></div><div class="cg2"><div class="cd" onclick="op('16_gdp_per_capita_map.html')" style="animation-delay:0.00s"><div class="cs" style="background:#2ECC40"></div><div class="cb"><div class="ct"><span class="cn">16</span></div><h3>GDP per Capita</h3><p class="dp">GDP per capita in PPP dollars. The global wealth map. Two orders of magnitude between richest and poorest.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('17_trade_openness_map.html')" style="animation-delay:0.04s"><div class="cs" style="background:#2ECC40"></div><div class="cb"><div class="ct"><span class="cn">17</span></div><h3>Trade Openness</h3><p class="dp">Trade (exports+imports) as % of GDP. Small wealthy nations show extreme openness (Singapore >300%).</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('18_remittances_map.html')" style="animation-delay:0.08s"><div class="cs" style="background:#2ECC40"></div><div class="cb"><div class="ct"><span class="cn">18</span></div><h3>Remittances</h3><p class="dp">Remittances as % of GDP. Diaspora economies: Tonga 40%+, Nepal 25%+. The lifeline of migration.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-environment" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#27AE6022;color:#27AE60">&#127795;</div><div><h2>Environment</h2><p class="pd">Forest, renewables, water stress.</p></div></div><div class="cg2"><div class="cd" onclick="op('19_forest_cover_map.html')" style="animation-delay:0.00s"><div class="cs" style="background:#27AE60"></div><div class="cb"><div class="ct"><span class="cn">19</span></div><h3>Forest Cover</h3><p class="dp">Forest area as % of land. Amazon and Congo basins dominate. Critical carbon sinks under threat.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('20_renewable_energy_map.html')" style="animation-delay:0.04s"><div class="cs" style="background:#27AE60"></div><div class="cb"><div class="ct"><span class="cn">20</span></div><h3>Renewable Energy</h3><p class="dp">Renewable energy % of consumption. High values in poor countries = biomass, not modern renewables.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('21_water_stress_map.html')" style="animation-delay:0.08s"><div class="cs" style="background:#27AE60"></div><div class="cb"><div class="ct"><span class="cn">21</span></div><h3>Water Stress</h3><p class="dp">Freshwater withdrawals as % of renewable resources. >100% = unsustainable. MENA region critical.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-geovars" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#F39C1222;color:#F39C12">&#128200;</div><div><h2>Geo-Variables</h2><p class="pd">Latitude, distance, climate, conflict.</p></div></div><div class="cg2"><div class="cd" onclick="op('23_latitude_vs_gdp.html')" style="animation-delay:0.00s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">23</span></div><h3>Latitude-Wealth</h3><p class="dp">GDP vs absolute latitude. The geography hypothesis: tropical countries are systematically poorer. Strong positive correlation.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('24_megacity_distance_vs_lifeexp.html')" style="animation-delay:0.04s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">24</span></div><h3>Megacity-LifeExp</h3><p class="dp">Distance to nearest megacity vs life expectancy. The connectivity premium: proximity to economic hubs correlates with health.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('25_latitude_vs_child_mortality.html')" style="animation-delay:0.08s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">25</span></div><h3>Climate-Mortality</h3><p class="dp">Under-5 mortality vs latitude by climate zone. Tropical countries face higher mortality from disease burden.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('26_conflict_vs_development.html')" style="animation-delay:0.12s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">26</span></div><h3>Conflict</h3><p class="dp">UCDP conflict intensity vs GDP and life expectancy. Even moderate conflict costs 10-15 years of life.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('27_landlocked_vs_coastal.html')" style="animation-delay:0.16s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">27</span></div><h3>Sea Access</h3><p class="dp">GDP distributions: landlocked vs coastal by continent. Landlocked countries face 15-20% higher transport costs.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('28_digital_divide_latitude.html')" style="animation-delay:0.20s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">28</span></div><h3>Digital Divide</h3><p class="dp">Internet usage vs latitude, colored by income group. The digital divide parallels the development gradient.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('29_fertility_by_climate.html')" style="animation-delay:0.24s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">29</span></div><h3>Fertility-Climate</h3><p class="dp">Fertility distributions across 4 climate zones (violin plots). Tropical zones show widest spread, highest median.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('30_urbanization_vs_renewable.html')" style="animation-delay:0.28s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">30</span></div><h3>Urban-Renewables</h3><p class="dp">Urban % vs renewable energy. Counterintuitively negative: urban = more fossil fuels, rural = more biomass.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('31_water_stress_latitude.html')" style="animation-delay:0.32s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">31</span></div><h3>Arid Belt</h3><p class="dp">Water withdrawals vs latitude. The 20-35 degree arid belt concentrates extreme water stress.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('32_physicians_latitude.html')" style="animation-delay:0.36s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">32</span></div><h3>Healthcare-Lat</h3><p class="dp">Physicians per 1,000 vs latitude. Fewer doctors near the equator: brain drain + training gaps.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('33_education_megacity_distance.html')" style="animation-delay:0.40s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">33</span></div><h3>Education-Connectivity</h3><p class="dp">Primary school completion vs distance to nearest megacity. Geographic isolation predicts educational outcomes.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('34_trade_longitude.html')" style="animation-delay:0.44s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">34</span></div><h3>Trade E-W</h3><p class="dp">Trade openness vs longitude. Two peaks: Europe (0-30E) and East Asia (100-120E), the major trade blocs.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('35_maternal_mortality_forest.html')" style="animation-delay:0.48s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">35</span></div><h3>Forest-Maternal</h3><p class="dp">Maternal mortality vs forest cover. High forest = rural remoteness, poor healthcare access. Not inherently protective.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('36_remittances_latitude.html')" style="animation-delay:0.52s"><div class="cs" style="background:#F39C12"></div><div class="cb"><div class="ct"><span class="cn">36</span></div><h3>Remittance-Lat</h3><p class="dp">Remittances vs latitude. Low-latitude dependency reflects South-to-North migration patterns.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-india" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#FF993322;color:#FF9933">&#127470;&#127475;</div><div><h2>India Elections</h2><p class="pd">LISA, Moran's I, women's candidature/electorate/forfeiture analysis, area, turnout across 543 constituencies.</p></div></div><div class="cg2"><div class="cd" onclick="op('37_india_lisa_clusters.html')" style="animation-delay:0.00s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">37</span></div><h3>LISA Clusters</h3><p class="dp">LISA clusters for turnout (I=0.64) and margin (I=0.26). KNN k=8. Hot spots in south, cold spots in Hindi belt.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('38_india_area_outcomes.html')" style="animation-delay:0.04s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">38</span></div><h3>Area-Outcomes</h3><p class="dp">Constituency area (log km2) vs turnout and margin. Larger seats = lower turnout. Area autocorrelated (I=0.16).</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('39_india_moran_scatterplot.html')" style="animation-delay:0.08s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">39</span></div><h3>Moran's I</h3><p class="dp">Moran's I scatterplot. Slope = spatial autocorrelation. HH/LL = clustering. HL/LH = spatial outliers.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('40_india_turnout_swing.html')" style="animation-delay:0.12s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">40</span></div><h3>Turnout Swing</h3><p class="dp">Turnout change 2019-2024. Red = dropped, Blue = rose. National avg: -1.4pp. Geographic disengagement visible.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('41_india_distance_delhi_margin.html')" style="animation-delay:0.16s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">41</span></div><h3>Center-Periphery</h3><p class="dp">Victory margin vs distance from Delhi. Tests the core-periphery model. No strong distance decay effect.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('46_women_area_hypothesis.html')" style="animation-delay:0.20s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">46</span></div><h3>Women+Area</h3><p class="dp">Three panels: area distribution by winner gender, density vs margin, category breakdown. Mann-Whitney test significant.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('48_alliance_lisa_women.html')" style="animation-delay:0.24s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">48</span></div><h3>Alliance LISA</h3><p class="dp">LISA on alliance alignment (I=0.37). 110 NDA + 112 INDIA strongholds. Women's representation uncorrelated with alliance.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('54_women_lisa_fixed.html')" style="animation-delay:0.28s"><div class="cs" style="background:#FF9933"></div><div class="cb"><div class="ct"><span class="cn">54</span></div><h3>Women LISA Fixed</h3><p class="dp">LISA on women winners (I=0.06, weak but significant). Right: area vs density scatter. Women cluster slightly.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('65_silence_map.html')" style="animation-delay:0.32s">
<div class="cs" style="background:#FF0040"></div><div class="cb">
<div class="ct"><span class="cn">65</span><span class="cg">Geo Scatter</span></div>
<h3>The Silence Map</h3><p class="dp">152 constituencies (28%) where NO woman even ran. Red X marks = total absence. Color gradient from red (zero) to green (4+ women candidates).</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('66_the_gauntlet.html')" style="animation-delay:0.36s">
<div class="cs" style="background:#FF8C00"></div><div class="cb">
<div class="ct"><span class="cn">66</span><span class="cg">Funnel</span></div>
<h3>The Gauntlet</h3><p class="dp">A woman's brutal path: 8,360 candidates total, only 458 women. Of those, 325 (71%) lost their deposit. Only 47 won a seat. An interactive funnel of elimination.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('67_gender_gap_electorate.html')" style="animation-delay:0.40s">
<div class="cs" style="background:#FF5872"></div><div class="cb">
<div class="ct"><span class="cn">67</span><span class="cg">Diverging Bar</span></div>
<h3>Gender Gap in the Electorate</h3><p class="dp">Female voters per 1,000 male voters by state. Bihar (907), Haryana, J&K have the worst gender gaps. Kerala, AP exceed parity. Gold line = 1000.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('68_deposit_forfeiture.html')" style="animation-delay:0.44s">
<div class="cs" style="background:#FF2D55"></div><div class="cb">
<div class="ct"><span class="cn">68</span><span class="cg">Strip Plot</span></div>
<h3>The Deposit Forfeiture Massacre</h3><p class="dp">Every single woman candidate plotted by vote share. 325 dots in the red zone (lost deposit). 86 in gold (lost, kept deposit). 47 green (won). Each dot is a name.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('69_state_scoreboard.html')" style="animation-delay:0.48s">
<div class="cs" style="background:#FFD700"></div><div class="cb">
<div class="ct"><span class="cn">69</span><span class="cg">Triple Panel</span></div>
<h3>State Scoreboard</h3><p class="dp">Three dimensions side by side: women elected, deposit forfeit rate, and voter gender ratio. 14 states elected zero women. Some have 100% forfeit rates.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('70_women_candidature_3d.html')" style="animation-delay:0.52s">
<div class="cs" style="background:#2ECC40"></div><div class="cb">
<div class="ct"><span class="cn">70</span><span class="cg">3D Scatter</span></div>
<h3>Women Candidature Terrain 3D</h3><p class="dp">Height = % women candidates per constituency. Red X on the floor = zero women ran. Rotatable 3D view over India. The geography of exclusion made tangible.</p>
<div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-delimitation" style="display:none;flex-direction:column">
<div class="ph"><div class="pi" style="background:#E6550022;color:#E65500">&#9878;</div>
<div><h2>Delimitation & Fiscal Analysis</h2><p class="pd">Delimitation simulation, fiscal return bias, women's reservation scenarios, Moran's I criteria exploration, punishment values, and representation inequality. Slider-driven animations.</p></div></div>
<div class="cg2">
<div class="cd" onclick="op('71_delimitation_simulator.html')" style="animation-delay:0.0s">
<div class="cs" style="background:#FF5872"></div><div class="cb">
<div class="ct"><span class="cn">71</span><span class="cg">Animated Scatter</span></div>
<h3>Delimitation Simulator</h3><p class="dp">Drag slider from 543 to 1000 total seats. Watch population-proportional reallocation: southern states (red) lose share, northern states (green) gain. Gold diagonal = no change.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('72_fiscal_returns.html')" style="animation-delay:0.04s">
<div class="cs" style="background:#FF851B"></div><div class="cb">
<div class="ct"><span class="cn">72</span><span class="cg">Diverging Bar</span></div>
<h3>Fiscal Returns: Rs per 100</h3><p class="dp">For every Rs 100 in tax, how much does your state get back? Tamil Nadu: Rs 29.7. Bihar: Rs 142.5. Red = net contributors. Green = net recipients. Source: 15th Finance Commission.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('73_reservation_simulator.html')" style="animation-delay:0.08s">
<div class="cs" style="background:#FFD700"></div><div class="cb">
<div class="ct"><span class="cn">73</span><span class="cg">Animated Scatter</span></div>
<h3>Women Reservation Simulator</h3><p class="dp">Drag slider 0% to 100%. Watch guaranteed women representation rise across states. At 33%: ~180 seats. At 50%: ~272. Current reality: 47 seats (8.7%).</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('74_moran_criteria_explorer.html')" style="animation-delay:0.12s">
<div class="cs" style="background:#00D5E0"></div><div class="cb">
<div class="ct"><span class="cn">74</span><span class="cg">Moran Curve</span></div>
<h3>Moran's I Criteria Explorer</h3><p class="dp">Which delimitation criteria produces less spatial clustering? Slide weight between area vs population, and women voters vs fiscal returns. Lower Moran's I = more equitable dispersion.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('75_punishment_value_3d.html')" style="animation-delay:0.16s">
<div class="cs" style="background:#FF0040"></div><div class="cb">
<div class="ct"><span class="cn">75</span><span class="cg">3D Scatter</span></div>
<h3>The Punishment Value</h3><p class="dp">Fiscal return x female voter % x seats in 3D. Color = punishment value (1 - 0.35*fiscal/100). Red = most punished states (pay most, get least, fewest women). Tamil Nadu, Maharashtra in deep red.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('76_representation_inequality.html')" style="animation-delay:0.20s">
<div class="cs" style="background:#7FEB00"></div><div class="cb">
<div class="ct"><span class="cn">76</span><span class="cg">Animated Bar</span></div>
<h3>Representation Inequality</h3><p class="dp">Electors per seat by state. Drag slider 543 to 1000 seats. Watch bars equalize as seats increase. Perfect equity = flat bars. Currently UP has 2.4M voters per seat vs Sikkim 0.4M.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('77_fiscal_spine.html')" style="animation-delay:0.24s">
<div class="cs" style="background:#FF851B"></div><div class="cb">
<div class="ct"><span class="cn">77</span><span class="cg">Geo Spine</span></div>
<h3>The Fiscal Spine</h3><p class="dp">States connected south-to-north by latitude. Size = seats. Color = fiscal return. The spine reveals: net contributors cluster at the bottom (south), net recipients at the top (north).</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('78_representation_treemap.html')" style="animation-delay:0.28s">
<div class="cs" style="background:#2ECC40"></div><div class="cb">
<div class="ct"><span class="cn">78</span><span class="cg">Treemap</span></div>
<h3>Democratic Real Estate</h3><p class="dp">Treemap of seats by region and state. Area = seats. Color = fiscal return. Click to drill into regions. The imbalance between population weight and fiscal contribution becomes spatial.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('79_fiscal_gender_bubble.html')" style="animation-delay:0.32s">
<div class="cs" style="background:#B10DC9"></div><div class="cb">
<div class="ct"><span class="cn">79</span><span class="cg">Animated Bubble</span></div>
<h3>Fiscal x Gender Bubble</h3><p class="dp">Fiscal returns vs women's representation with reservation slider (0-100%). Watch women % rise uniformly. Southern net-contributors remain underrepresented even with quotas.</p>
<div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('80_constituency_clustering.html')" style="animation-delay:0.36s">
<div class="cs" style="background:#FF2D55"></div><div class="cb">
<div class="ct"><span class="cn">80</span><span class="cg">Color Map</span></div>
<h3>Constituency Clustering</h3><p class="dp">Every constituency color-coded by % women candidates. Continuous color scale: deep red = 0%, green = 25%+. The spatial clustering of women's exclusion across India. Source: ECI 2024.</p>
<div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="tp" id="p-immersive" style="display:none;flex-direction:column"><div class="ph"><div class="pi" style="background:#B10DC922;color:#B10DC9">&#127922;</div><div><h2>3D Immersive</h2><p class="pd">Three.js: terrains, helices, crystals, auroras, orbits, spirals, particle fields.</p></div></div><div class="cg2"><div class="cd" onclick="op('42_india_political_cylinder.html')" style="animation-delay:0.00s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">42</span></div><h3>Political Cylinder</h3><p class="dp">543 constituencies on rotating 3D cylinder. Height = latitude, angle = longitude, color = alliance. North-South divide revealed.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('43_development_globe.html')" style="animation-delay:0.04s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">43</span></div><h3>Dev Globe</h3><p class="dp">196 countries on rotating sphere. Bars = GDP/lifeExp/fertility (switchable). Northern hemisphere towers over South in GDP mode.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('44_democracy_helix.html')" style="animation-delay:0.08s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">44</span></div><h3>Democracy Helix</h3><p class="dp">NDA and INDIA alliances spiral in DNA double helix. South at bottom, north top. Node size = margin. The bipolar geography.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('45_continental_dev_space.html')" style="animation-delay:0.12s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">45</span></div><h3>Continental Development Space</h3><p class="dp">196 countries in 3D space: GDP x Life Expectancy x Fertility. Continental clusters visible. No 2D projection loss.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('47_3d_extruded_india.html')" style="animation-delay:0.16s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">47</span></div><h3>3D Extruded India</h3><p class="dp">3D bars over India. Height = electorate ratio/turnout/margin (switchable). The spatial histogram concept in action.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('55_india_party_flip_3d.html')" style="animation-delay:0.20s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">55</span></div><h3>Party Flip 3D</h3><p class="dp">214 flipped constituencies pulse with golden rings. Stable seats glow softly. The dynamic part of Indian democracy.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('56_development_spiral.html')" style="animation-delay:0.24s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">56</span></div><h3>Dev Spiral</h3><p class="dp">Countries trace spiral paths through time (1952-2007). Radius = GDP, height = life expectancy. Slider scrubs years.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('59_india_dev_terrain.html')" style="animation-delay:0.28s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">59</span><span class="cg">3D Terrain</span></div><h3>India Development Terrain</h3><p class="dp">30 states as glowing pillars. 8 switchable metrics: HDI, GSDP, literacy, sex ratio, IMR, urbanization, forest, food. Width = area. Sources: Census 2011, RBI, MoSPI.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('60_india_food_geography_3d.html')" style="animation-delay:0.32s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">60</span><span class="cg">3D Orbits</span></div><h3>India Food Geography 3D</h3><p class="dp">Green diamonds = rice, gold squares = wheat. Height above India = production in million tonnes. Geographic positions preserved. Sources: MoSPI, RBI.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('61_literacy_gender_helix.html')" style="animation-delay:0.36s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">61</span><span class="cg">3D DNA Helix</span></div><h3>Literacy-Gender DNA Helix</h3><p class="dp">Two intertwined strands: literacy (cyan) and sex ratio (magenta). States ordered by HDI bottom-to-top. Bridges connect the same state across metrics. Sources: Census 2011.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('62_constituency_aurora.html')" style="animation-delay:0.40s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">62</span><span class="cg">3D Particle Field</span></div><h3>Constituency Aurora</h3><p class="dp">543 constituencies as breathing particles. They pulse vertically with turnout, glow with margin intensity. Vertical beams for high-margin seats. Alliance-colored aurora. Source: ECI.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('63_india_socioeconomic_3d.html')" style="animation-delay:0.44s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">63</span><span class="cg">3D Crystal Stack</span></div><h3>India Socioeconomic Landscape 3D</h3><p class="dp">X=Literacy, Y=GSDP per capita, Z=HDI. Size=population, color=region (south to north). Drop lines show HDI height. Sources: Census, RBI, MoSPI.</p><div class="ca">Open chart &rarr;</div></div></div>
<div class="cd" onclick="op('64_gender_development_3d.html')" style="animation-delay:0.48s"><div class="cs" style="background:#B10DC9"></div><div class="cb"><div class="ct"><span class="cn">64</span><span class="cg">3D Scatter</span></div><h3>Gender-Development Nexus 3D</h3><p class="dp">X=Sex Ratio, Y=Infant Mortality (reversed), Z=Literacy. Color=sex ratio (red=low, green=high). Size=population. Kerala vs Haryana in stark 3D contrast. Sources: Census, SRS.</p><div class="ca">Open chart &rarr;</div></div></div>
</div></div>
<div class="sf"><h3>Sources</h3><p><b>World Bank</b> <a href="https://data.worldbank.org/">data.worldbank.org</a> | <b>ECI</b> <a href="https://data.opencity.in/">OpenCity.in</a> | <b>Census of India 2011</b> <a href="https://censusindia.gov.in/">censusindia.gov.in</a> | <b>RBI</b> Handbook of Statistics | <b>MoSPI</b> Statistical Yearbook | <b>DataMeet</b> <a href="https://github.com/datameet">github.com/datameet</a> | <b>Gapminder</b> <a href="https://www.gapminder.org/">gapminder.org</a> | <b>NOAA</b> ERSST v5, CRW | <b>UCDP/PRIO</b> | <b>Anselin (1995)</b>: LISA | <b>Rosling et al. (2018)</b>: Factfulness | <b>Sachs (2001)</b>: Tropical Underdevelopment</p></div></div><div class="ov" id="ov"><button class="xb" onclick="cl()">&#215;</button><iframe id="cf" src=""></iframe></div><script>function sw(id){document.querySelectorAll(".tp").forEach(function(p){p.style.display="none"});document.querySelectorAll(".tb").forEach(function(b){b.classList.remove("active")});var p=document.getElementById("p-"+id);if(p){p.style.display="flex";p.style.flexDirection="column"}var b=document.getElementById("b-"+id);if(b)b.classList.add("active")}function op(f){document.getElementById("cf").src=f;document.getElementById("ov").classList.add("sh");document.body.style.overflow="hidden"}function cl(){document.getElementById("ov").classList.remove("sh");document.getElementById("cf").src="";document.body.style.overflow="auto"}document.addEventListener("keydown",function(e){if(e.key==="Escape")cl()});</script></body></html>